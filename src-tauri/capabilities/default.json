{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
 "windows": ["main", "open_project", "start",  "editor", "create_project"],
  "permissions": [
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:path:allow-resolve-directory",
    "core:path:default",
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-write",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-mkdir",
    "fs:allow-create",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    }
  ]
}